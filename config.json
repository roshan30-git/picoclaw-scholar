{
    "_comment": "StudyClaw Configuration — copy this to ~/.studyclaw/config.json and fill in your values.",
    "gemini": {
        "api_key": "PASTE_YOUR_GEMINI_API_KEY_HERE",
        "model": "gemini-1.5-flash",
        "max_tokens": 8192
    },
    "whatsapp": {
        "session_file": "~/.studyclaw/whatsapp_session.json",
        "allowed_groups": [
            "YOUR_STUDY_GROUP_NAME_OR_ID"
        ],
        "owner_number": "+91XXXXXXXXXX"
    },
    "workspace": {
        "path": "~/.studyclaw/workspace",
        "db_path": "~/.studyclaw/studyclaw.db",
        "prompts_dir": "~/.studyclaw/workspace/PROMPTS"
    },
    "scheduler": {
        "daily_quiz_time": "20:00",
        "exam_reminder_days_before": 14,
        "heartbeat_interval_minutes": 30
    }
}